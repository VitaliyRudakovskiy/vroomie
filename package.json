{
	"name": "vroomie",
	"version": "1.0.0",
	"scripts": {
		"ng": "ng",
		"start": "ng serve",
		"build": "ng build",
		"watch": "ng build --watch --configuration development",
		"test": "ng test",
		"check": "biome check ./src",
		"check:fix": "biome check --write --unsafe ./src && prettier --write \"src/**/*.html\"",
		"format": "biome format --write ./src && prettier --write \"src/**/*.html\"",
		"lint": "biome lint ./src"
	},
	"private": true,
	"packageManager": "pnpm@10.33.0",
	"dependencies": {
		"@angular/common": "20.3.18",
		"@angular/compiler": "20.3.18",
		"@angular/core": "20.3.18",
		"@angular/forms": "20.3.18",
		"@angular/platform-browser": "20.3.18",
		"@angular/router": "20.3.18",
		"@angular/fire": "20.0.1",
		"firebase": "11.10.0",
		"@ngrx/effects": "^20.1.0",
		"@ngrx/store": "^20.1.0",
		"@ngrx/store-devtools": "^20.1.0",
		"rxjs": "~7.8.0",
		"tslib": "^2.3.0"
	},
	"devDependencies": {
		"@angular/build": "20.3.18",
		"@angular/cli": "20.3.18",
		"@angular/compiler-cli": "20.3.18",
		"@biomejs/biome": "^2.4.10",
		"jsdom": "^29.0.1",
		"prettier": "^3.8.1",
		"typescript": "5.8.2",
		"vitest": "^3.1.1"
	}
}
